# ==========================================
# CMS Project Environment Variables Template
# ==========================================
# .gemini.md Safety Rule:
# 1. 이 파일의 이름을 .env로 복사하여 사용하세요.
# 2. 실제 비밀번호나 API Key는 절대 이 파일(버전 관리)에 포함하지 마세요.

# --- Database (MariaDB) ---
CMS_MARIADB_PASSWORD=change_this_to_secure_root_password
CMS_DB_APP_PASSWORD=change_this_to_secure_app_password
CMS_DB_USER=funnycms
CMS_DB_NAME=cmsdb

# --- Backend (Flask) ---
FLASK_APP=app.py
FLASK_DEBUG=1
SECRET_KEY=generate_a_random_secret_key_here

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:5000

# --- AI Service (Gemini) ---
GEMINI_API_KEY=your_google_gemini_api_key_here