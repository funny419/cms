# [Development] Environment Variables Template
# 사용법: 이 파일을 복사하여 .env 파일을 생성하세요. (cp .env.dev.example .env)

# --- Database (MariaDB) ---
# 개발용이므로 비밀번호가 노출되어도 안전한 값을 사용하세요.
CMS_MARIADB_PASSWORD=dev_root_password
CMS_DB_APP_PASSWORD=dev_app_password
CMS_DB_USER=funnycms
CMS_DB_NAME=cmsdb

# --- Backend (Flask) ---
FLASK_APP=app.py
FLASK_DEBUG=1
SECRET_KEY=dev_secret_key_dont_use_in_prod

# --- Frontend (Vite) ---
# 로컬 개발 환경 주소
VITE_API_BASE_URL=http://localhost:5000

# --- AI Service (Gemini) ---
# 개인 개발용 API 키를 입력하세요.
GEMINI_API_KEY=your_dev_api_key